# Copy to .env at the repo root (NOT backend/). The backend reads these via
# pydantic-settings; names are case-insensitive and map to Settings fields.

# ── Required ──
COHERE_API_KEY=                      # embeddings + Rerank v3 (always needed)
ANTHROPIC_API_KEY=                   # Claude (default provider)

# ── Optional providers ──
GEMINI_API_KEY=                      # only if LLM_PROVIDER=gemini

# Which backend the agent/synthesis use: anthropic | gemini | local
LLM_PROVIDER=anthropic
# Anthropic model. Dev/eval = Sonnet; public deploy overrides to Haiku.
CLAUDE_MODEL=claude-sonnet-4-6

# ── Vector store ──
QDRANT_URL=     # cloud cluster URL in prod
QDRANT_API_KEY=                      # required for Qdrant Cloud, empty locally

# ── Local / edge model (only when LLM_PROVIDER=local; Ollama on :11434) ──
LOCAL_MODEL=llama3.2:3b
LOCAL_BASE_URL=http://localhost:11434/v1
LOCAL_USE_TOOLS=true                 # false = degraded synthesis-only mode

# ── Misc ──
LLM_MODE=cloud
DUCKDB_PATH=./data/duckdb/finrag.duckdb

# ── Public-deploy guardrails (see docs/deploy.md) ──
# Comma-separated CORS allow-list. Prod = your exact Vercel origin.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
RATE_LIMIT_PER_MIN=8                 # per-IP, on the paid endpoints
DAILY_QUESTION_CAP=300               # global cost circuit-breaker (per UTC day)
